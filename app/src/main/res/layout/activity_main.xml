<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0A0A"
    android:padding="24dp">

    <!-- Header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ॐ"
        android:textColor="#FF8C00"
        android:textSize="48sp"
        android:gravity="center"
        android:fontFamily="serif"
        android:layout_marginTop="32dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Gita Darshan"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:gravity="center"
        android:fontFamily="serif"
        android:layout_marginTop="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Bhagavad Gita on your screen"
        android:textColor="#888888"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="40dp" />

    <!-- Enable/Disable Switch Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/card_bg"
        android:padding="20dp"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Show Gita Verses"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Display verse on screen off"
                android:textColor="#888888"
                android:textSize="13sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <Switch
            android:id="@+id/switchService"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:thumbTint="#FF8C00"
            android:trackTint="#442200" />
    </LinearLayout>

    <!-- Status text -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#AAAAAA"
        android:textSize="13sp"
        android:gravity="center"
        android:layout_marginBottom="32dp"
        android:lineSpacingMultiplier="1.4" />

    <!-- Settings button -->
    <Button
        android:id="@+id/btnSettings"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="⚙  Settings"
        android:textColor="#FF8C00"
        android:textSize="15sp"
        android:background="@drawable/btn_outline"
        android:stateListAnimator="@null" />

    <!-- Info footer -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Requires KernelSU root and overlay permission.\nVerses from all 18 chapters of Bhagavad Gita."
        android:textColor="#555555"
        android:textSize="12sp"
        android:gravity="center"
        android:lineSpacingMultiplier="1.5"
        android:layout_marginTop="32dp" />

</LinearLayout>
